<Project>
    <Target Name="ZipOutputPath" AfterTargets="Build" Condition="'$(Storefront)' != 'gog'">
        <PropertyGroup>
            <StagingDir>$(TEMP)\GYK_staging\$(MSBuildProjectName)</StagingDir>
            <PluginDir>$(StagingDir)\plugins\$(MSBuildProjectName)</PluginDir>
            <ReleasesDir>$(MSBuildThisFileDirectory)AAA_Releases</ReleasesDir>
        </PropertyGroup>

        <RemoveDir Directories="$(StagingDir)" />
        <MakeDir Directories="$(PluginDir)" />
        <MakeDir Directories="$(ReleasesDir)" />

        <ItemGroup>
            <!-- *.vortex_backup / *.vortex_new are leftovers Vortex writes into the plugin dir when it deploys
                 or rolls back a previous version. They live alongside the real files (including inside lang/)
                 and would otherwise get scooped up by the glob below.
                 Locations\ holds Beam Me Up Gerry's runtime user-created custom zones, not shipped content. -->
            <OutputFiles Include="$(OutputPath)\**\*.*"
                         Exclude="$(OutputPath)\**\*.zip;$(OutputPath)\**\*.pdb;$(OutputPath)\**\*.deps.json;$(OutputPath)\**\*.csv;$(OutputPath)\**\*.vortex_backup;$(OutputPath)\**\*.vortex_new;$(OutputPath)\SaveBackup\**\*.*;$(OutputPath)\_dump\**\*.*;$(OutputPath)\Locations\**\*.*" />
        </ItemGroup>

        <Copy SourceFiles="@(OutputFiles)"
              DestinationFiles="@(OutputFiles->'$(PluginDir)\%(RecursiveDir)%(Filename)%(Extension)')" />

        <Copy Condition="Exists('$(MSBuildProjectDirectory)\CHANGELOG.md')"
              SourceFiles="$(MSBuildProjectDirectory)\CHANGELOG.md"
              DestinationFolder="$(PluginDir)" />

        <ZipDirectory Overwrite="true"
                      SourceDirectory="$(StagingDir)"
                      DestinationFile="$(ReleasesDir)\$(MSBuildProjectName)_v$(Version)_BepInEx.zip" />

        <RemoveDir Directories="$(StagingDir)" />
    </Target>
</Project>
